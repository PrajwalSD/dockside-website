---
/**
 * Product + FAQ JSON-LD for /dockside-app (SoftwareApplication, FAQPage).
 */
import { SITE } from 'astrowind:config';

export interface FaqItem {
  title: string;
  description: string;
}

export interface Props {
  faqItems: FaqItem[];
}

const { faqItems } = Astro.props;

const base = String(SITE.site || '').replace(/\/$/, '');
const pageUrl = `${base}/dockside-app`;

function toPlainText(html: string): string {
  return html
    .replace(/<a\s[^>]*href="([^"]*)"[^>]*>([^<]*)<\/a>/gi, '$2 ($1)')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

const faqMainEntity = faqItems.map((item) => ({
  '@type': 'Question',
  name: item.title,
  acceptedAnswer: {
    '@type': 'Answer',
    text: toPlainText(item.description),
  },
}));

/** Curated for search + AI summaries; mirrors /features highlights without listing every row. */
const featureList = [
    'Native macOS file shelf beside the Dock (Dock companion, not a Dock replacement)',
    'Drag-and-drop staging for files, folders, Finder tags, apps, URLs, and plain text',
    'Smart drag activation and tunable drop zones',
    'Multiple Files shelf areas (columns) with names, icons, and per-area folder watch',
    'Recent screenshots and Downloads strip with previews and shortcuts',
    'Search and paging on the Files shelf',
    'Clipboard history and pasteboard-aware flows where supported',
    'Works with hidden Dock and full-screen apps; multi-monitor and Spaces aware',
    'Third-party integrations via dockside:// URL actions',
    'Apple Notarized; offline-first; lifetime license with 14-day trial',
  ];

const graph = [
  {
    '@type': 'SoftwareApplication',
    '@id': `${pageUrl}#software`,
    name: 'Dockside',
    applicationCategory: 'UtilitiesApplication',
    additionalType: 'https://schema.org/DesktopApplication',
    operatingSystem: 'macOS 13.0 or later',
    featureList,
    offers: {
      '@type': 'Offer',
      price: '5.99',
      priceCurrency: 'USD',
      description: 'Lifetime license; 14-day free trial available',
      url: 'https://hachipoo.gumroad.com/l/dockside',
    },
    downloadUrl: 'https://hachipoo.com/distributions/Dockside.dmg',
    url: pageUrl,
    description:
      'Dockside is a native Mac file shelf and Dock-side companion for staging files before you open or move them. Drag and drop files, folders, links, apps, and text; quick access to recent screenshots, downloads, and monitored folders—built for shelf workflows next to the macOS Dock. Apple Notarized; works offline.',
    author: { '@id': `${base}/#organization` },
    publisher: { '@id': `${base}/#organization` },
  },
  {
    '@type': 'FAQPage',
    '@id': `${pageUrl}#faq`,
    url: pageUrl,
    mainEntity: faqMainEntity,
  },
];

const json = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': graph,
});
---

<script type="application/ld+json" set:html={json} />
