---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links?: Array<Links>;
  secondaryLinks: Array<Link>;
  connectLinks?: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], connectLinks = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-700/80 not-prose bg-slate-50/50 dark:bg-slate-900/50']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-8 md:py-14">
    <div
      class="grid grid-cols-1 gap-8 overflow-x-hidden md:gap-10 lg:gap-12 md:grid-cols-[minmax(0,1.85fr)_minmax(0,1fr)] lg:grid-cols-[minmax(0,2fr)_minmax(0,0.85fr)]"
    >
      <!-- Brand + links: two columns on md+ (brand | link grid); stacked on small screens -->
      <div class="min-w-0 grid grid-cols-1 gap-8 text-center md:grid-cols-[minmax(0,14rem)_minmax(0,1fr)] md:items-start md:gap-10 md:text-left lg:grid-cols-[minmax(0,16rem)_minmax(0,1fr)] lg:gap-12">
        <div class="mx-auto flex max-w-md flex-col items-center gap-4 md:mx-0 md:max-w-none md:items-start">
          <a
            href={getHomePermalink()}
            class="inline-block transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-900"
            aria-label="Hachipoo Apps — home"
          >
            <img
              src="/logo.png"
              alt=""
              width="200"
              height="80"
              loading="lazy"
              decoding="async"
              class="h-16 w-auto object-contain object-left sm:h-[4.5rem] md:h-20"
              aria-hidden="true"
            />
          </a>
          <div class="text-center md:text-left">
            <a
              class="inline-block font-bold text-xl md:text-2xl text-gray-900 dark:text-white hover:text-primary dark:hover:text-primary transition-colors"
              href={getHomePermalink()}>{SITE?.name}</a>
            <p class="mt-2 text-sm text-muted dark:text-slate-400 md:mt-3">
              Indie Mac apps that simplify your workflow.
            </p>
          </div>
        </div>
        <div class="mx-auto w-full max-w-sm text-center sm:max-w-md md:mx-0 md:max-w-none md:text-left">
          <h3
            id="footer-links-heading"
            class="mb-3 text-base font-semibold text-gray-900 dark:text-white md:mb-4"
          >
            Links
          </h3>
          <nav
            class="grid w-full grid-cols-2 gap-x-5 gap-y-2 text-sm justify-items-center sm:gap-x-8 md:justify-items-start"
            aria-labelledby="footer-links-heading"
          >
            {
              secondaryLinks.map(({ text, href }) => (
                <a
                  class="inline-flex min-h-9 items-center text-muted hover:text-gray-900 dark:text-gray-300 dark:hover:text-white hover:underline transition-colors"
                  href={href}
                  set:html={text}
                />
              ))
            }
          </nav>
        </div>
      </div>

      <!-- Connect & Follow: single column on small phones; two columns from md up -->
      {(connectLinks?.length > 0 || socialLinks?.length > 0) && (
        <div class="flex w-full min-w-0 max-w-full flex-col gap-8 text-center md:text-left lg:max-w-xs lg:justify-self-end xl:max-w-sm">
          {connectLinks?.length > 0 && (
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-3 md:mb-4 text-base">Connect & Support</h3>
              <ul class="space-y-2 md:space-y-3">
                {connectLinks.map(({ text, href, icon, ariaLabel }) => (
                  <li class="flex min-h-10 items-center justify-center md:min-h-8 md:justify-start">
                    <a
                      class="inline-flex max-w-full items-center gap-2 text-sm text-muted hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      {icon && <Icon name={icon} class="h-5 w-5 shrink-0 text-primary" />}
                      <span class="min-w-0 break-words [overflow-wrap:anywhere]">{text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {socialLinks?.length > 0 && (
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-3 md:mb-4 text-base">Follow</h3>
              <ul class="space-y-2 md:space-y-3">
                {socialLinks.map(({ ariaLabel, href, icon, text }) => (
                  <li class="flex min-h-10 items-center justify-center md:min-h-8 md:justify-start">
                    <a
                      class="inline-flex min-h-10 max-w-full items-center gap-2 text-sm text-muted hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors md:min-h-0"
                      aria-label={ariaLabel}
                      href={href}
                    >
                      <Icon name={icon} class="h-5 w-5 shrink-0" />
                      {text || ariaLabel}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}
    </div>

    <div class="mt-8 md:mt-12 pt-6 md:pt-8 border-t border-gray-200/80 dark:border-slate-700/60 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-center sm:text-left">
      <div class="text-sm text-muted dark:text-slate-400 flex items-center justify-center sm:justify-start">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
