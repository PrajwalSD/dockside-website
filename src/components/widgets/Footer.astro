---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links?: Array<Links>;
  secondaryLinks: Array<Link>;
  connectLinks?: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], connectLinks = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-700/80 not-prose bg-slate-50/50 dark:bg-slate-900/50']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-8 md:py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2 text-center">
        <a class="inline-block font-bold text-xl md:text-2xl text-gray-900 dark:text-white hover:text-primary dark:hover:text-primary transition-colors" href={getHomePermalink()}>{SITE?.name}</a>
        <p class="mt-2 md:mt-3 text-sm text-muted dark:text-slate-400 max-w-sm mx-auto">
          Indie Mac apps that simplify your workflow.
        </p>
        <nav class="mt-4 md:mt-6 grid grid-cols-2 sm:flex sm:flex-wrap gap-x-6 gap-y-2 sm:gap-x-4 sm:gap-y-1 text-sm max-w-xs mx-auto sm:max-w-none justify-items-center sm:justify-center" aria-label="Footer navigation">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <a
                class="text-muted hover:text-gray-900 dark:text-gray-300 dark:hover:text-white hover:underline transition-colors"
                href={href}
                set:html={text}
              />
            ))
          }
        </nav>
      </div>

      <!-- Connect & Follow (aligned rows) -->
      {(connectLinks?.length > 0 || socialLinks?.length > 0) && (
        <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-y-8 sm:gap-y-0 gap-x-8 lg:gap-x-12 text-center md:text-left">
          {connectLinks?.length > 0 && (
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-3 md:mb-4 text-base">Connect & Support</h3>
              <ul class="space-y-2 md:space-y-3">
                {connectLinks.map(({ text, href, icon, ariaLabel }) => (
                  <li class="min-h-8 flex items-center justify-center md:justify-start">
                    <a
                      class="inline-flex items-center gap-2 text-sm text-muted hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      {icon && <Icon name={icon} class="w-5 h-5 text-primary shrink-0" />}
                      <span class="break-all">{text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {socialLinks?.length > 0 && (
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-3 md:mb-4 text-base">Follow</h3>
              <ul class="space-y-2 md:space-y-3">
                {socialLinks.map(({ ariaLabel, href, icon, text }) => (
                  <li class="min-h-8 flex items-center justify-center md:justify-start">
                    <a
                      class="inline-flex items-center gap-2 text-sm text-muted hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
                      aria-label={ariaLabel}
                      href={href}
                    >
                      <Icon name={icon} class="w-5 h-5 shrink-0" />
                      {text || ariaLabel}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}
    </div>

    <div class="mt-8 md:mt-12 pt-6 md:pt-8 border-t border-gray-200/80 dark:border-slate-700/60 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-center sm:text-left">
      <div class="text-sm text-muted dark:text-slate-400 flex items-center justify-center sm:justify-start">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
