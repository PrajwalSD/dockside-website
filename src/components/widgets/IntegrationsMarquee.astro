---
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { Icon } from 'astro-icon/components';

const INTEGRATION_APPS = [
  { name: 'Clop', url: 'https://lowtechguys.com/clop/#integration', icon: 'https://lowtechguys.com/static/img/clop-icon.png' },
  { name: 'Popclip', url: 'https://www.popclip.app/extensions/x/p8rrp7', icon: 'https://www.popclip.app/icon128.png' },
  { name: 'Dropshare', url: 'https://dropshare.app/', icon: 'https://dropshare.app/logo.png' },
];
---

<WidgetWrapper id="integrations" isDark={false} containerClass="max-w-4xl">
  <Headline
    tagline="Integrations"
    title="Works with your favourite apps"
    subtitle="Dockside integrates seamlessly with tools you already use."
  />

  <div class="flex flex-wrap justify-center gap-4 md:gap-6 py-6 md:py-8">
    {INTEGRATION_APPS.map((app) => (
      <a
        href={app.url}
        target="_blank"
        rel="noopener noreferrer"
        class="integrations-card group flex flex-col items-center gap-3 flex-shrink-0 w-[140px] md:w-[160px] rounded-2xl border border-slate-200/80 dark:border-slate-600/50 bg-white/90 dark:bg-slate-800/80 backdrop-blur-sm p-5 shadow-lg hover:shadow-xl hover:scale-[1.03] hover:border-slate-300 dark:hover:border-slate-500 transition-all duration-300"
      >
        <img
          src={app.icon}
          alt={`${app.name} icon`}
          class="w-12 h-12 md:w-14 md:h-14 rounded-xl object-contain"
          loading="lazy"
          decoding="async"
        />
        <span class="text-sm font-semibold text-slate-700 dark:text-slate-200 group-hover:text-primary transition-colors text-center">
          {app.name}
        </span>
      </a>
    ))}
    <a
      href="/integrations"
      class="integrations-card group flex flex-col items-center justify-center gap-3 flex-shrink-0 w-[140px] md:w-[160px] rounded-2xl border-2 border-dashed border-slate-300 dark:border-slate-600 bg-slate-50/50 dark:bg-slate-800/40 p-5 shadow-sm hover:shadow-md hover:border-slate-400 dark:hover:border-slate-500 transition-all duration-300"
    >
      <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl flex items-center justify-center bg-slate-200/80 dark:bg-slate-700/80 text-slate-500 dark:text-slate-400">
        <Icon name="tabler:plus" class="w-6 h-6 md:w-7 md:h-7" />
      </div>
      <span class="text-sm font-medium text-slate-500 dark:text-slate-400 text-center">
        Add yours
      </span>
    </a>
  </div>
</WidgetWrapper>
