---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';
import type { CallToAction as Props } from '~/types';

const {
  variant = 'secondary',
  target,
  text = Astro.slots.render('default'),
  icon = '',
  iconPosition = 'end',
  class: className = '',
  type,
  ...rest
} = Astro.props;

const iconHostClass = 'inline-flex shrink-0 items-center justify-center';
const iconSvgClass = 'block h-5 w-5 shrink-0';

const variants = {
  primary: 'btn-primary',
  secondary: 'btn-secondary',
  tertiary: 'btn btn-tertiary',
  link: 'cursor-pointer hover:text-primary',
};

const withIconGap = icon ? 'gap-1.5 flex-nowrap' : '';
---

{
  type === 'button' || type === 'submit' || type === 'reset' ? (
    <button type={type} class={twMerge(variants[variant] || '', withIconGap, className)} {...rest}>
      {icon && iconPosition === 'start' && (
        <span class={iconHostClass} aria-hidden="true">
          <Icon name={icon} class={iconSvgClass} />
        </span>
      )}
      <span class={icon ? 'min-w-0 shrink leading-snug' : undefined} set:html={text} />
      {icon && iconPosition !== 'start' && (
        <span class={iconHostClass} aria-hidden="true">
          <Icon name={icon} class={iconSvgClass} />
        </span>
      )}
    </button>
  ) : (
    <a
      class={twMerge(variants[variant] || '', withIconGap, className)}
      {...(target ? { target: target, rel: 'noopener noreferrer' } : {})}
      {...rest}
    >
      {icon && iconPosition === 'start' && (
        <span class={iconHostClass} aria-hidden="true">
          <Icon name={icon} class={iconSvgClass} />
        </span>
      )}
      <span class={icon ? 'min-w-0 shrink leading-snug' : undefined} set:html={text} />
      {icon && iconPosition !== 'start' && (
        <span class={iconHostClass} aria-hidden="true">
          <Icon name={icon} class={iconSvgClass} />
        </span>
      )}
    </a>
  )
}
