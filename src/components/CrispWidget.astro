---
/* Crisp loads only in the browser via the script below. */
---

<script>
  const CRISP_ID = '535090dc-a6a2-46a9-a9d2-8ad08c18482f';

  function initCrisp() {
    if (typeof window === 'undefined') return;
    import('crisp-sdk-web').then(({ Crisp }) => {
      Crisp.configure(CRISP_ID);
    });
  }

  initCrisp();
  document.addEventListener('astro:page-load', initCrisp);
</script>
