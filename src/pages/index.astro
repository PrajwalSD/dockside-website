---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Hachipoo Apps',
  ignoreTitleTemplate: true,
};
---
<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Learn more',
        href: '/dockside-app',
        target: ''
      }
    ]}
  >
  {/* Add image above the title */}
  
    <Fragment slot="title">
      <a
        href="/dockside-app"
        class="mb-4 block w-full rounded-2xl shadow-sm ring-offset-2 ring-offset-[var(--aw-color-bg-page)] transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent dark:ring-offset-slate-900"
        aria-label="Dockside for Mac — open app page"
      >
        <img
          class="shadow-sm"
          src="/appIcon1024px.png"
          alt=""
          style={{
            display: 'block',
            margin: '0 auto',
            width: '20%',
            height: '20%',
            objectFit: 'cover',
            marginTop: '-3rem',
            marginBottom: '1rem',
          }}
        />
      </a>
      <span class="text-accent dark:text-white highlight no-margin">Dockside for Mac</span>
	   <span class="hidden xl:inline"></span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="sm:inline">
        <span class="font-semibold">Dockside</span> 
        is your friendly file shelf next to the macOS Dock, where you can drag and drop files, folders, apps, images, videos, and text for quick access or later use, without interrupting your workflow. 
		Explore all of Dockside’s features with a free 14-day trial, or purchase a one-time license for just $5.99, no subscriptions. 
		Supports macOS 13.0+ (Ventura and above)
    </Fragment>
  </Hero>

</Layout>
