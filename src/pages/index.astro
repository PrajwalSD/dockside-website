---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Dockside — Mac file shelf & Dock companion | Hachipoo Apps',
  ignoreTitleTemplate: true,
  description:
    'Dockside: a native macOS file shelf next to your Dock for drag-and-drop staging—files, folders, apps, media, and text—with screenshots, downloads, and folder watch. Offline, Apple Notarized, macOS 13+. 14-day trial; $5.99 lifetime.',
  openGraph: {
    title: 'Dockside — Mac file shelf & Dock companion',
    description:
      'Native macOS shelf app beside the Dock: staging, screenshots & downloads strip, folder watch, drop zones. Try free for 14 days.',
    type: 'website',
  },
};
---
<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Learn more',
        href: '/dockside-app',
        target: ''
      }
    ]}
  >
  {/* Add image above the title */}
  
    <Fragment slot="title">
      <a
        href="/dockside-app"
        class="mb-4 block w-full rounded-2xl shadow-sm ring-offset-2 ring-offset-[var(--aw-color-bg-page)] transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent dark:ring-offset-slate-900"
        aria-label="Dockside for Mac — open app page"
      >
        <img
          class="shadow-sm"
          src="/appIcon1024px.png"
          alt=""
          style={{
            display: 'block',
            margin: '0 auto',
            width: '20%',
            height: '20%',
            objectFit: 'cover',
            marginTop: '-3rem',
            marginBottom: '1rem',
          }}
        />
      </a>
      <span class="text-accent dark:text-white highlight no-margin">Dockside for Mac</span>
	   <span class="hidden xl:inline"></span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="sm:inline">
        <span class="font-semibold">Dockside</span>{' '}
        is a native Mac file shelf and Dock companion: a staging strip beside the macOS Dock where you drag and drop files, folders, apps, images, videos, and text for quick access or later hand-off—without floating windows in the middle of your work. If you are comparing{' '}
        <span class="font-semibold">shelf apps for macOS</span> or a Dock-adjacent extension for file flow, Dockside is purpose-built for that strip-next-to-Dock workflow (see the{' '}
        <a href="/features" class="text-link underline decoration-slate-400/60 underline-offset-2 hover:decoration-current">
          full feature list
        </a>
        ). Explore everything with a free 14-day trial, or a one-time license for $5.99—no subscriptions. Supports macOS 13.0+ (Ventura and above).
      </span>
    </Fragment>
  </Hero>

</Layout>
