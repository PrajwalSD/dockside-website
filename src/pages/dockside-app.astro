---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import { Icon } from 'astro-icon/components';
import HeroText from '~/components/widgets/HeroText.astro';

import Prices from '~/components/widgets/Pricing.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
// import RedditFeed from '~/components/widgets/RedditFeed.astro';
import IntegrationsMarquee from '~/components/widgets/IntegrationsMarquee.astro';
import FeaturedInStrip from '~/components/widgets/FeaturedInStrip.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';
import SectionImage from '~/components/common/SectionImage.astro';
import VimeoAutoplayOnVisible from '~/components/VimeoAutoplayOnVisible.astro';
import DocksideJsonLd from '~/components/seo/DocksideJsonLd.astro';

import { docksideFaqItems } from '~/data/docksideFaqItems';

const appStoreImg = '~/assets/images/app-store.png';
const appStoreDownloadLink = 'https://github.com/onwidget/astrowind';

const googlePlayImg = '~/assets/images/google-play.png';
const googlePlayDownloadLink = 'https://github.com/onwidget/astrowind';

const docksideMetaDescription =
  'Dockside for Mac: native file shelf and Dock companion beside your Dock—staging for files, folders, links, apps, and text; recent screenshots & downloads; folder watch and drop zones. Apple Notarized, offline, macOS 13+. 14-day trial; $5.99 lifetime.';

const metadata = {
  title: 'Dockside for Mac — native file shelf & Dock companion (drag, drop, done)',
  ignoreTitleTemplate: true,
  description: docksideMetaDescription,
  openGraph: {
    title: 'Dockside for Mac — file shelf & Dock companion',
    description: docksideMetaDescription,
    type: 'website',
  },
};

const featuredReviewTsiu = `THE app I've been searching for since forever! I've tried all similar ones (Yoink, Dropover, Dropshelf, etc.), but none have this standout feature: quick access to the latest screenshots and downloaded files, complete with previews and all possible shortcuts right on top. Everything is visible at a glance and accessible with just one click, plus it's all in an unused part of the screen. Brilliant, just brilliant. Combined with CleanShotX, Dropover, and Clop, it's the perfect setup for me. And the pricing—$6 for a lifetime license? So affordable and rare these days... I bought the app after only an hour of trial! 🤣 Thank you so much.`;

const featuredReviewHerman = 'The ghost of Steve Jobs approves of this.';

const featuredReviewAndrew = 'This is the best file shelf app for macOS. Period.';

