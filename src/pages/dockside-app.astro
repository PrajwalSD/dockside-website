  <script>
	function loadGitHubStats() {
	  const el = document.getElementById('github-stats');
	  if (!el) return;
	  fetch('https://api.github.com/repos/PrajwalSD/Dockside/releases?per_page=100', {
		headers: { Accept: 'application/vnd.github.v3+json' }
	  })
		.then((r) => r.json())
		.then((releases) => {
		  if (!Array.isArray(releases) || releases.length === 0) {
			el.innerHTML = '<span class="text-muted opacity-80">View releases</span>';
			return;
		  }
		  const latest = releases[0];
		  const tag = latest.tag_name || '';
		  const pub = latest.published_at ? new Date(latest.published_at) : null;
		  const dateStr = pub ? pub.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
		  const count = releases.length;
		  const countStr = count >= 100 ? '100+' : count;
		  const dot =
			'<span class="mx-1.5 text-slate-400/35 dark:text-slate-500/40 select-none" aria-hidden="true">•</span>';
		  el.innerHTML = `<span class="font-medium text-page opacity-90 dark:opacity-95">${tag}</span>${dot}<span>${dateStr}</span>${dot}<span>${countStr} releases</span>`;
		})
		.catch(() => {
		  el.innerHTML = '<span class="text-muted opacity-80">View releases →</span>';
		});
	}
	loadGitHubStats();
	document.addEventListener('astro:page-load', loadGitHubStats);

	function closeDocksideHomebrewModal() {
	  const modal = document.getElementById('dockside-homebrew-modal');
	  if (!modal) return;
	  modal.classList.add('hidden');
	  modal.classList.remove('flex');
	  document.body.classList.remove('overflow-hidden');
	}

	function initDocksideHomebrewModal() {
	  const modal = document.getElementById('dockside-homebrew-modal');
	  const openBtn = document.getElementById('dockside-open-homebrew-modal');
	  const cmdEl = document.getElementById('dockside-brew-command-text');
	  const copyBtn = document.getElementById('dockside-brew-copy');
	  if (!modal || !openBtn) return;

	  const open = () => {
		modal.classList.remove('hidden');
		modal.classList.add('flex');
		document.body.classList.add('overflow-hidden');
	  };

	  openBtn.onclick = (e) => {
		e.preventDefault();
		open();
	  };
	  modal.querySelectorAll('[data-homebrew-modal-close]').forEach((el) => {
		el.onclick = () => closeDocksideHomebrewModal();
	  });

	  if (copyBtn && cmdEl) {
		copyBtn.onclick = async () => {
		  const text = (cmdEl.textContent || '').trim() || 'brew install --cask dockside';
		  try {
			await navigator.clipboard.writeText(text);
		  } catch {
			return;
		  }
		  const ic = copyBtn.querySelector('.dockside-brew-copy-icon');
		  const ok = copyBtn.querySelector('.dockside-brew-copied-icon');
		  ic?.classList.add('hidden');
		  ok?.classList.remove('hidden');
		  setTimeout(() => {
			ic?.classList.remove('hidden');
			ok?.classList.add('hidden');
		  }, 1600);
		};
	  }
	}

	if (!document.documentElement.dataset.docksideBrewEsc) {
	  document.documentElement.dataset.docksideBrewEsc = '1';
	  document.addEventListener('keydown', (e) => {
		if (e.key !== 'Escape') return;
		const modal = document.getElementById('dockside-homebrew-modal');
		if (modal && modal.classList.contains('flex')) closeDocksideHomebrewModal();
	  });
	}

	initDocksideHomebrewModal();
	document.addEventListener('astro:page-load', initDocksideHomebrewModal);
  </script>

