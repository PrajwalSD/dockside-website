  <!-- Homebrew install modal (opened from hero secondary button) -->
  <div
    id="dockside-homebrew-modal"
    class="fixed inset-0 z-[200] hidden items-center justify-center p-4 sm:p-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="dockside-homebrew-modal-title"
