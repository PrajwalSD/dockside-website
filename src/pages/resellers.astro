---
import Layout from '~/layouts/PageLayout.astro';
const metadata = {
  title: 'Official reseller in Greater China — Dockside',
  description:
    'Hachipoo Apps authorises DIGITALYCHEE (数码荔枝) as the official partner for Dockside in Greater China. Official stores: lizhi.shop and digitalychee.taobao.com.',
  ignoreTitleTemplate: false,
};
---

<Layout metadata={metadata}>
  <article
    class="mx-auto max-w-2xl px-5 pb-16 pt-10 text-default md:px-6 md:pb-24 md:pt-14"
    data-reveal="section"
  >
    <header class="mb-10 text-center md:mb-14">
      <a href="/" class="inline-block">
        <img
          src="/logo.png"
          alt="Hachipoo Apps"
          class="mx-auto h-10 w-auto opacity-90 md:h-12"
          width={120}
          height={40}
          loading="eager"
        />
      </a>
      <h1 class="mt-8 text-2xl font-bold tracking-tight text-heading dark:text-slate-100 md:text-3xl">
        Official reseller in Greater China
      </h1>
    </header>

    <div class="space-y-10 border-t border-slate-200/90 pt-10 dark:border-slate-600/60 md:space-y-12 md:pt-12">
      <section aria-labelledby="auth-zh-heading">
        <h2 id="auth-zh-heading" class="mb-5 text-center text-base font-semibold text-heading dark:text-slate-100">
          授权证明
        </h2>
        <div
          class="space-y-6 text-[0.95rem] leading-[1.75] text-slate-800 dark:text-slate-300 md:text-base"
          lang="zh-Hans"
        >
          <p>
            Hachipoo Apps 授权<strong class="font-semibold text-heading dark:text-slate-100">「数码荔枝」</strong>为大中国区官方合作伙伴。
          </p>
          <div>
            <p class="text-sm text-muted dark:text-slate-400">负责以下软件在中国的销售事宜</p>
            <p class="mt-1 font-semibold text-heading dark:text-slate-100">Dockside</p>
          </div>
          <div>
            <p class="text-sm text-muted dark:text-slate-400">该合作伙伴的销售渠道</p>
            <p class="mt-1">
              <a
                href="https://lizhi.shop"
                class="text-accent underline decoration-slate-400/60 underline-offset-2 hover:opacity-90 dark:text-blue-400 dark:decoration-slate-500/60"
                target="_blank"
                rel="noopener noreferrer">lizhi.shop</a>
              {' / '}
              <a
                href="https://digitalychee.taobao.com"
                class="text-accent underline decoration-slate-400/60 underline-offset-2 hover:opacity-90 dark:text-blue-400 dark:decoration-slate-500/60"
                target="_blank"
                rel="noopener noreferrer">digitalychee.taobao.com</a>
            </p>
          </div>
        </div>
      </section>

      <hr class="border-slate-200 dark:border-slate-600/60" />

      <section aria-labelledby="auth-en-heading">
        <h2
          id="auth-en-heading"
          class="mb-5 text-center text-sm font-semibold uppercase tracking-[0.12em] text-heading dark:text-slate-100 md:text-base"
        >
          Authorization Certificate
        </h2>
        <div class="space-y-6 text-[0.95rem] leading-[1.75] text-slate-800 dark:text-slate-300 md:text-base">
          <p>
            We, <strong class="font-semibold text-heading dark:text-slate-100">Hachipoo Apps</strong>, authorize
            <strong class="font-semibold text-heading dark:text-slate-100">DIGITALYCHEE</strong> as our official partner
            in China.
          </p>
          <div>
            <p class="text-sm text-muted dark:text-slate-400">Responsible for the sales of the following product(s)</p>
            <p class="mt-1 font-semibold text-heading dark:text-slate-100">Dockside</p>
          </div>
          <div>
            <p class="text-sm text-muted dark:text-slate-400">Authorized Sales Channels</p>
            <p class="mt-1">
              <a
                href="https://lizhi.shop"
                class="text-accent underline decoration-slate-400/60 underline-offset-2 hover:opacity-90 dark:text-blue-400 dark:decoration-slate-500/60"
                target="_blank"
                rel="noopener noreferrer">lizhi.shop</a>
              {' / '}
              <a
                href="https://digitalychee.taobao.com"
                class="text-accent underline decoration-slate-400/60 underline-offset-2 hover:opacity-90 dark:text-blue-400 dark:decoration-slate-500/60"
                target="_blank"
                rel="noopener noreferrer">digitalychee.taobao.com</a>
            </p>
          </div>
        </div>
      </section>
    </div>

    <footer class="mt-14 border-t border-slate-200/90 pt-10 text-center dark:border-slate-600/60">
      <img
        src="/li_logo.png"
        alt="DIGITALYCHEE · 数码荔枝"
        class="mx-auto h-14 w-auto max-w-[min(100%,360px)] object-contain opacity-95 md:h-16"
        width={704}
        height={270}
        loading="lazy"
        decoding="async"
      />
      <p class="mt-2 text-xs text-muted dark:text-slate-500">
        <a href="/dockside-app" class="underline decoration-slate-400/50 underline-offset-2 hover:opacity-90">Dockside for Mac</a>
        ·
        <a href="/contact" class="underline decoration-slate-400/50 underline-offset-2 hover:opacity-90">Contact</a>
      </p>
    </footer>
  </article>
</Layout>
